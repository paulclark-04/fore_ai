# Fore AI Lead Scoring Pipeline — Environment Variables
# Copy this to .env and fill in your actual API keys

# Apollo API (for lead search)
APOLLO_API_KEY=your_apollo_api_key_here

# Apify (for lead search + LinkedIn enrichment)
APIFY_API_TOKEN=apify_api_your_token_here

# Google Gemini (for AI title filtering + scoring)
GOOGLE_API_KEY=your_google_api_key_here

# Google Sheets (for export)
GOOGLE_SHEETS_ID=your_google_sheet_id_here
